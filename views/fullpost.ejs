<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/x-icon" href="/img/icon.png">
    <link rel="stylesheet" href="/css/style.css">
    <title>
        <%= post.title || 'Post' %>
    </title>
</head>

<body>
    <%- include('partials/header', {sessionUser, showActions: true}) %>

    <main class="feed-container">
        <%- include('partials/post', {post, sessionUser, showControls: true}) %>

        <% if (locals.errorMessage) { %>
            <div class="error-badge">
                <%= errorMessage %>
            </div>
        <% } %> 

        <section id="comment-section" class="comment-post-section">
            <form action="/fullpost/<%= post._id %>/comment" method="POST" class="comment-post-form">
                <textarea name="text" placeholder="Comment here..." id="commentText"
                    class="comment-post-textarea" required></textarea>
                <button type="submit" class="neo-btn neo-btn-red comment-post-btn">
                    COMMENT
                </button>
            </form>
        </section>

        <%- include('partials/sortTabs', { 
            baseUrl: '/fullpost/' + post._id, 
            resetUrl: '/fullpost/reset-sort/' + post._id, 
            currentSort 
        }) %> 

        <section>
            <% if (comments && comments.length > 0) { %>
                <% comments.forEach((comment) => { %>
                    <%- include('partials/comment', {comment, sessionUser, showControls: true}) %>
                <% }); %>
            <% } else { %>
                <p>No comments yet. Be the first to comment!</p>
            <% } %>
        </section>
    </main>
</body>

</html>
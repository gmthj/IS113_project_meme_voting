<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/x-icon" href="/img/icon.png">
    <title><%= post.title || 'Post' %></title>
</head>
<%- include('partials/header', {sessionUser}) %>

    <body>
        <section>
            <%- include('partials/post', {post, sessionUser, showControls: true}) %>
        </section>

        <section style="white-space: nowrap;">
            <form action="/fullpost/<%= post._id %>/comment" method="POST">
                <textarea style="
                    resize: none; 
                    width: 100%; 
                    max-width: 18em; 
                    height: 4.5em; 
                    display: inline-block; 
                    vertical-align: top;
                    margin-right: -4px;
                " name="text" placeholder="Comment here..." id="commentText" required></textarea>

                <input style="
                    width: 6em; 
                    height: 5em; 
                    display: inline-block; 
                    vertical-align: top;
                " type="submit" value="Comment">
            </form>
        </section>

        <section>
            <% if (comments && comments.length > 0) { %>
                <% comments.forEach((comment) => { %>
                    <%- include('partials/comment', {comment, sessionUser, showControls: true}) %>
                <% }); %>
            <% } else { %>
                <p>No comments yet. Be the first to comment!</p>
            <% } %>
        </section>

    </body>

</html>
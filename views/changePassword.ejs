<!-- This is for user who login and manaully change the password by clicking change password -->
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/x-icon" href="/img/icon.png">
    <link rel="stylesheet" href="/css/style.css">
    <title>Edit Password</title>
</head>

<body>
    <%- include('partials/header', { sessionUser, showActions: true }) %>

    <main class="home-container form-center-wrapper">
        <div class="neo-card">
            <div class="neo-card-header">
                <h2>CHANGE PASSWORD</h2>
            </div>
            <div class="neo-card-body">
                <p class="account-info-text">ACCOUNT: <%= sessionUser.email %></p>

                <% if (error) { %>
                    <div class="error-message">
                    <% if (Array.isArray(error)) { %>
                        <ul>
                        <% error.forEach(function(err) { %>
                            <li><%= err %></li>
                        <% }); %>
                        </ul>
                    <% } else { %>
                        <p><%= error %></p>
                    <% } %>
                    </div>
                <% } %>
            
                <% if (success) { %>
                    <div id="successMessage" class="neo-success-sticker flash-msg"></div>
            
                    <script>
                        let seconds = 3;
                        const messageEl = document.getElementById("successMessage");
            
                        function updateMessage() {
                            messageEl.textContent = `Password updated successfully, redirecting to account in ${seconds}s`;
                        }
            
                        updateMessage();
            
                        const interval = setInterval(() => {
                            seconds--;
            
                            if (seconds > 0) {
                                updateMessage();
                            } else {
                                clearInterval(interval);
                                window.location.href = "/user/<%= sessionUser._id %>";
                            }
                        }, 1000);
                    </script>
                <% } %>
            
                <form action="/account/change-password" method="POST">
                    <div class="neo-form-group">
                        <label for="currentPassword" class="neo-label">Current Password:</label>
                        <input type="password" id="currentPassword" name="currentPassword" required class="neo-input">
                    </div>
            
                    <div class="neo-form-group">
                        <label for="newPassword" class="neo-label">New Password:</label>
                        <input type="password" id="newPassword" name="newPassword" required class="neo-input">
                    </div>
            
                    <div class="neo-form-group last">
                        <label for="confirmPassword" class="neo-label">Confirm New Password:</label>
                        <input type="password" id="confirmPassword" name="confirmPassword" required class="neo-input">
                    </div>
            
                    <button type="submit" class="neo-btn neo-btn-yellow full-width">UPDATE PASSWORD</button>
                </form>
            </div>
            <div class="neo-card-footer neo-footer-row form-center-wrapper" style="margin-top: 0;">
                <a href="/user/<%= sessionUser._id %>" class="neo-btn neo-btn-white">BACK TO PROFILE</a>
            </div>
        </div>
    </main>
</body>
</html>
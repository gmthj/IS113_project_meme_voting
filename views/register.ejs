<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/x-icon" href="/img/icon.png">
    <link rel="stylesheet" href="/css/style.css">
    <title>Register</title>
</head>

<body>
    <%- include('partials/header', {sessionUser, showActions: true}) %>

    <main class="home-container form-center-wrapper">
        <div class="neo-card">
            <div class="neo-card-header">
                <h2>REGISTER PAGE</h2>
            </div>
            <div class="neo-card-body">
                <% if (error) { %>
                    <div class="error-message">
                    <% if (Array.isArray(error)) { %>
                        <ul>
                        <% error.forEach(function(err) { %>
                            <li><%= err %></li>
                        <% }); %>
                        </ul>
                    <% } else { %>
                        <p><%= error %></p>
                    <% } %>
                    </div>
                <% } %>
            
                <form action="/account/register" method="post">
                    <div class="neo-form-group">
                        <label for="email" class="neo-label">Email:</label>
                        <input type="email" id="email" name="email" value="<%= formData.email || '' %>" required class="neo-input">
                    </div>
            
                    <div class="neo-form-group">
                        <label for="name" class="neo-label">Full Name:</label>
                        <input type="text" id="name" name="name" value="<%= formData.name || '' %>" required class="neo-input">
                    </div>
            
                    <div class="neo-form-group">
                        <label for="dob" class="neo-label">Date of Birth (must be at least <%= MIN_AGE %> years old):</label>
                        <input type="date" id="dob" name="dob" value="<%= formData.dob || '' %>" required class="neo-input">
                    </div>
            
                    <div class="neo-form-group">
                        <label for="bio" class="neo-label">Bio:</label>
                        <textarea name="bio" id="bio" rows="4" class="neo-input"><%= formData.bio || '' %></textarea>
                    </div>
            
                    <div class="neo-form-group">
                        <label for="password" class="neo-label">Password:</label>
                        <input type="password" id="password" name="password" required class="neo-input">
                    </div>
            
                    <div class="neo-form-group last">
                        <label for="confirmation" class="neo-label">Confirm Password:</label>
                        <input type="password" id="confirmation" name="confirmation" required class="neo-input">
                    </div>
            
                    <button type="submit" class="neo-btn neo-btn-yellow full-width">REGISTER NOW</button>
                </form>
            </div>
            <div class="neo-card-footer neo-footer-column">
                <p class="card-footer-msg">Already have an account?</p>
                <a href="/account/login" class="neo-btn neo-btn-white">LOGIN HERE</a>
            </div>
        </div>
    </main>
    
</body>

<script>
    const dateInput = document.getElementById("dob");

    if (dateInput) {
        dateInput.addEventListener("click", function () {
            if (this.showPicker) {
                this.showPicker();
            }
        });
    }
</script>

</html>
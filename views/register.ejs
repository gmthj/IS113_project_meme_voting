<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/x-icon" href="/img/icon.png">
    <link rel="stylesheet" href="/css/style.css">
    <title>Register</title>
</head>

<body>
    <%- include('partials/header', {sessionUser, showActions: true}) %>

    <div class="home-container">
        <h1>Register Here!</h1>
    
        <% if (error) { %>
            <div class="error-message" style="color: red; font-weight: bold; margin-bottom: 20px;">
            <% if (Array.isArray(error)) { %>
                <ul style="margin: 0; padding-left: 20px;">
                <% error.forEach(function(err) { %>
                    <li style="margin-bottom: 5px;"><%= err %></li>
                <% }); %>
                </ul>
            <% } else { %>
                <p style="margin: 0;"><%= error %></p>
            <% } %>
            </div>
        <% } %>
    
        <form action="/account/register" method="post">
            <label for="email">Email:</label>
            <input type="email" id="email" name="email" value="<%= formData.email || '' %>" required>
            <br><br>
    
            <label for="name">Full Name:</label>
            <input type="text" id="name" name="name" value="<%= formData.name || '' %>" required>
            <br><br>
    
            <label for="dob">Date of Birth: (must be at least <%= MIN_AGE %> years old)</label>
            <input type="date" id="dob" name="dob" value="<%= formData.dob || '' %>" required>
            <br><br>
    
            <label for="bio">Bio:</label>
            <br>
            <textarea name="bio" id="bio" rows="5" cols="40"><%= formData.bio || '' %></textarea>
            <br><br>
    
            <label for="password">Password:</label>
            <input type="password" id="password" name="password" required>
            <br><br>
    
            <label for="confirmation">Confirm Password:</label>
            <input type="password" id="confirmation" name="confirmation" required>
            <br><br>
    
            <button type="submit" class="neo-btn">Register</button>
        </form>
    
        <p>Already have an account? <a href="/account/login">Login here</a></p>
    </div>
    
</body>

<script>
    const dateInput = document.getElementById("dob");

    if (dateInput) {
        dateInput.addEventListener("click", function () {
            if (this.showPicker) {
                this.showPicker();
            }
        });
    }
</script>

</html>
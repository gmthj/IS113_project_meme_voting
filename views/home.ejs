<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/x-icon" href="/img/icon.png">
    <link rel="stylesheet" href="/css/style.css">
    <title>THE DAILY DANK - Home</title>
</head>

<body>
    <%- include('partials/header', {sessionUser, showActions: (isAnnon || (sessionUser && sessionUser._id)) }) %>

    <div class="home-container">
        <div class="feed-header">
            <h1 class="feed-title">Meme Gallery</h1>
        </div>

        <% if (isAnnon || (sessionUser && sessionUser._id)) { %>
            <main class="feed-container">
                <%- include('partials/sortTabs', { baseUrl: '/home', resetUrl: '/home/reset-sort', currentSort }) %>

                <% if (posts && posts.length > 0) { %>
                    <% posts.forEach(post => { %>
                        <%- include('partials/post', {post, sessionUser, showControls: true}) %>
                    <% }); %>
                <% } else if (bookmarkError) { %>
                    <div style="border: 3px dashed #ccc; padding: 40px; text-align: center; font-weight: bold; color: #888;">
                        <%= bookmarkError %>
                    </div>
                <% } else { %>
                    <div style="border: 3px dashed #ccc; padding: 40px; text-align: center; font-weight: bold; color: #888;">
                        No memes found. Be the first to upload one!
                    </div>
                <% } %>
            </main>

            <% if (totalPages && totalPages > 1) { %>
                <div style="display:flex; justify-content:center; align-items:center; gap:16px; margin:20px 0;">
                    <% if (currentPage > 1) { %>
                        <a class="neo-btn" href="/home?sort=<%= currentSort || 'highest-votes' %><%= onlyBookmarks ? '&bookmark=true' : '' %><%= isAnnon ? '&annon=true' : '' %>&page=<%= currentPage - 1 %>">Previous</a>
                    <% } else { %>
                        <span class="neo-btn" style="opacity:0.5; pointer-events:none;">Previous</span>
                    <% } %>

                    <span style="font-weight:700;">Page <%= currentPage %> / <%= totalPages %></span>

                    <% if (currentPage < totalPages) { %>
                        <a class="neo-btn" href="/home?sort=<%= currentSort || 'highest-votes' %><%= onlyBookmarks ? '&bookmark=true' : '' %><%= isAnnon ? '&annon=true' : '' %>&page=<%= currentPage + 1 %>">Next</a>
                    <% } else { %>
                        <span class="neo-btn" style="opacity:0.5; pointer-events:none;">Next</span>
                    <% } %>
                </div>
            <% } %>

        <% } else { %>
            <div class="login-prompt">
                <h2 style="margin-bottom: 20px;">Welcome to Meme Vote!</h2>
                <p style="margin-bottom: 40px; color: #666;">Login to vote, comment, and bookmark memes.</p>
                <a href="/account/login" class="big-login-btn">Login now</a>
                <a href="/home?annon=true" class="big-login-btn">Continue Anonymously</a>
            </div>
        <% } %>
    </div>

    <%- include('partials/backToTop') %>
</body>

</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/x-icon" href="/img/icon.png">
    <link rel="stylesheet" href="/css/style.css">
    <title>Meme Gallery - Home</title>
    <style>
        .home-container {
            max-width: 900px;
            margin: 20px auto;
            padding: 0 20px;
        }

        .feed-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 20px;
            border-bottom: 4px solid #000;
            padding-bottom: 10px;
        }

        .feed-title {
            font-size: 2.5rem;
            text-transform: uppercase;
            margin: 0;
            line-height: 1;
        }

        /* Sorting Tabs */
        .sort-wrapper {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 30px;
            flex-wrap: nowrap;
        }

        .sort-left {
            display: flex;
            align-items: center;
        }

        .sort-tabs {
            display: flex;
            background: #fff;
            border: 3px solid #000;
            box-shadow: 4px 4px 0px #000;
            flex-shrink: 0;
        }

        .sort-tab {
            padding: 8px 16px;
            text-decoration: none;
            color: #000;
            font-weight: bold;
            border-right: 3px solid #000;
            font-size: 0.9rem;
            transition: background 0.2s;
            white-space: nowrap;
        }

        .sort-tab:last-child {
            border-right: none;
        }

        .sort-tab:hover {
            background: #f0f0f0;
        }

        .sort-tab.active {
            background: #ffeb3b;
        }

        .bookmark-tab {
            border: 3px solid #000;
            box-shadow: 4px 4px 0px #000;
            text-decoration: none;
            color: #000;
            font-weight: bold;
            padding: 8px 16px;
            background: #fff;
            white-space: nowrap;
        }

        .bookmark-tab:hover {
            background: #f0f0f0;
        }

        .bookmark-tab.active {
            background: #ffeb3b;
        }

        .sort-tabs form {
            margin: 0;
            padding: 0;
            display: flex;
        }

        .reset-btn {
            background: #ff5252;
            color: white;
            border: none;
            border-left: 3px solid #000;
            padding: 8px 12px;
            font-weight: bold;
            cursor: pointer;
            font-size: 0.9rem;
            white-space: nowrap;
        }

        .reset-btn:hover {
            background: #e53935;
        }

        .reset-btn:active {
            transform: translate(2px, 2px);
            box-shadow: 0px 0px 0px #000;
        }

        /* Login Prompt */
        .login-prompt {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 100px 20px;
            text-align: center;
        }

        .big-login-btn {
            background: #ffeb3b;
            color: #000;
            border: 4px solid #000;
            padding: 20px 40px;
            font-size: 1.5rem;
            font-weight: bold;
            text-decoration: none;
            box-shadow: 8px 8px 0px #000;
            text-transform: uppercase;
        }

        .big-login-btn:hover {
            transform: translate(-2px, -2px);
            box-shadow: 10px 10px 0px #000;
        }

        .big-login-btn:active {
            transform: translate(4px, 4px);
            box-shadow: 0px 0px 0px #000;
        }
    </style>
</head>

<body>
    <%- include('partials/header', {sessionUser, showActions: (isAnnon || (sessionUser && sessionUser._id)) }) %>

    <div class="home-container">
        <div class="feed-header">
            <h1 class="feed-title">Meme Gallery</h1>
            <!-- <div class="user-status">
                <% if (sessionUser && sessionUser._id) { %>
                    <span>Logged in as <strong><%= sessionUser.name %></strong></span>
                <% } %>
            </div> -->
        </div>

        <% if (isAnnon || (sessionUser && sessionUser._id)) { %>
            <!-- Sorting Interface (only shown when logged in) -->
            <div class="sort-wrapper">
                <div class="sort-left">
                    <div class="sort-tabs">
                        <a href="/home?sort=highest-votes" class="sort-tab <%= currentSort === 'highest-votes' ? 'active' : '' %>">TOP</a>
                        <a href="/home?sort=newest" class="sort-tab <%= currentSort === 'newest' ? 'active' : '' %>">NEWEST</a>
                        <a href="/home?sort=oldest" class="sort-tab <%= currentSort === 'oldest' ? 'active' : '' %>">OLDEST</a>
                        <a href="/home?sort=most-comments" class="sort-tab <%= currentSort === 'most-comments' ? 'active' : '' %>">MOST COMMENTS</a>
                        <form action="/home/reset-sort" method="POST" style="margin:0; padding:0;">
                            <button type="submit" class="reset-btn">RESET</button>
                        </form>
                    </div>
                </div>
                <a href="/home?sort=bookmarks" class="sort-tab bookmark-tab <%= currentSort === 'bookmarks' ? 'active' : '' %>">BOOKMARKS</a>
            </div>

            <!-- Display Posts -->
            <main class="feed-container">
                <% if (posts && posts.length > 0) { %>
                    <% posts.forEach(post => { %>
                        <%- include('partials/post', {post, sessionUser, showControls: true}) %>
                    <% }); %>
                <% } else { %>
                    <div style="border: 3px dashed #ccc; padding: 40px; text-align: center; font-weight: bold; color: #888;">
                        No memes found. Be the first to upload one!
                    </div>
                <% } %>
            </main>

        <% } else { %>
            <!-- Login Prompt (shown when not logged in) -->
            <div class="login-prompt">
                <h2 style="margin-bottom: 20px;">Welcome to Meme Vote!</h2>
                <p style="margin-bottom: 40px; color: #666;">Login to vote, comment, and bookmark memes.</p>
                <a href="/account/login" class="big-login-btn">Login now</a>
                <a href="/home?annon=true" class="big-login-btn">Continue Anonymously</a>
            </div>
        <% } %>

    </div>
</body>
</html>
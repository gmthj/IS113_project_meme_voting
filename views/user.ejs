<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/x-icon" href="/img/icon.png">
    <link rel="stylesheet" href="/css/style.css">
    <title><%= userInfo.name || "User" %></title>
</head>

<body>
    <%- include('partials/header', {sessionUser, showActions: true}) %>

    <div class="home-container">
        <div class="neo-card profile-card">
            <div class="profile-layout">
                <div class="profile-sidebar">
                    <div class="avatar-frame profile-page-avatar">
                        <img src="<%= userInfo.avatar %>" alt="avatar">
                    </div>
                    
                    <% if (sessionUser._id && sessionUser._id.toString() === userInfo._id.toString()) { %>
                        <a href="/account/edit" class="neo-btn-small" style="margin-top: 15px; text-decoration: none; display: inline-block;">
                            EDIT PROFILE
                        </a>
                    <% } %>
                </div>

                <div class="profile-info">
                    <h2 class="neo-title" style="margin-bottom: 5px;"><%= userInfo.name %></h2>
                    <div class="author-stats">
                        <span class="meta-text stat-tier"><%= userInfo.karmaTier %></span>
                        <span class="meta-text stat-karma"><%= userInfo.totalKarma %> KARMA</span>
                    </div>
                    <p class="meta-text" style="margin-bottom: 20px;">JOINED: <%= userInfo.joined %></p>

                    <div class="info-grid">
                        <div class="info-item">
                            <span class="neo-label-mini">EMAIL</span>
                            <p class="info-value"><%= userInfo.email %></p>
                        </div>
                        <!-- do not show birthday as it is used in forget password, show age instead -->
                        <!-- <div class="info-item">
                            <span class="neo-label-mini">BIRTHDAY</span>
                            <p class="info-value"><%= new Date(userInfo.dob).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }).toUpperCase() %></p>
                        </div> -->
                        
                        <div class="stats-row">
                            <div class="info-item">
                                <span class="neo-label-mini">AGE</span>
                                <p class="info-value text-upper"><%= userInfo.age %> OLD</p>
                            </div>
                            <div class="info-item">
                                <span class="neo-label-mini">POSTS</span>
                                <p class="info-value"><%= userInfo.postCount %></p>
                            </div>
                            <div class="info-item">
                                <span class="neo-label-mini">COMMENTS</span>
                                <p class="info-value"><%= userInfo.commentCount %></p>
                            </div>
                        </div>

                        <div class="info-item">
                            <span class="neo-label-mini">BIO</span>
                            <p class="info-value italic-bio">"<%= userInfo.bio %>"</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <hr>
        <h1> <%= userInfo.name %>'s Posts </h1>
        
        
        <main class="feed-container">
            <%- include('partials/sortTabs', { baseUrl: `/user/${userInfo._id}`, resetUrl: `/user/reset-sort`, currentSort }) %>

            <% if (userPosts && userPosts.length > 0) { %>
                <% userPosts.forEach(post => { %>
                    <%- include('partials/post', {post, sessionUser, showControls: true}) %>
                <% }); %>
            <% } else if (bookmarkError) { %>
                <div style="border: 3px dashed #ccc; padding: 40px; text-align: center; font-weight: bold; color: #888;">
                    <%= bookmarkError %>
                </div>
            <% } else { %>
                <div style="border: 3px dashed #ccc; padding: 40px; text-align: center; font-weight: bold; color: #888;">
                    No memes found. Be the first to upload one!
                </div>
            <% } %>
        </main>
    </div>

    <%- include('partials/backToTop') %>
</body>

</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/x-icon" href="/img/icon.png">
    <link rel="stylesheet" href="/css/style.css">
    <title>Users name</title>
</head>
<%- include('partials/header', {sessionUser}) %>
<body>
    1. show user info
    2. show user posts
    3. show user comments
    4. bookmarks


    Need to fix add edit button beside it
    <h3> Name: <%= userInfo.name %> </h3>
    <h3> Email: <%= userInfo.email %> </h3>
    <h3> Date of Birth: <%= userInfo.dob %> </h3>
    <h3> Bio: <%= userInfo.bio %> </h3>
    <h3> Avatar: <%= userInfo.avatar %> </h3>

    <hr>
    <h1> <%= userInfo.name %> </h1>
    
    <% if (userPost.length === 0) { %>
        <p>This user has no posts yet. </p>
    <% } %>


    <% userPost.forEach(post => { %>
        <%- include("partials/post", {
            post,
            sessionUser,
            showControls: true
        }) %>
    <% }) %>
    
</body>
</html>
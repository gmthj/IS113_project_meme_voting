<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="refresh" content="10;url=/home">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/x-icon" href="/img/icon.png">
    <link rel="stylesheet" href="/css/style.css">
    <title>ERROR!</title>
</head>

<body>
    <%- include('partials/header', {sessionUser || null}) %>

    <main class="error-main">
        <div class="error-card">
            <h1 class="error-badge">ERROR!</h1>
            
            <h3>OH NO! SOME THING WENT WRONG.</h3>
            <p class="meta-text">WE ENCOUNTERED AN ERROR WHILE PROCESSING YOUR REQUEST.</p>

            <% if(error) { %>
                <div class="error-details-box">
                    <strong>SYSTEM MESSAGE:</strong><br>
                    <%= error %>
                </div>
            <% } %>

            <div style="margin-top: 30px; display: flex; flex-direction: column; align-items: center; gap: 15px;">
                <a href="/home" class="neo-btn neo-btn-yellow">RETURN HOME NOW</a>
                
                <p id="countdown" class="countdown-text">
                    REDIRECTING AUTOMATICALLY IN 10 SECONDS...
                </p>
                <!-- <progress value="0" max="10" id="progressBar"></progress> -->
            </div>
        </div>
    </main>

</body>
</html>



<script>
// i stole this from stackoverflow fight me
// https://stackoverflow.com/questions/31106189/create-a-simple-10-second-countdown
var timeleft = 9;
var countdownTimer = setInterval(function(){
    document.getElementById("countdown").innerHTML = (timeleft > 0) ? `REDIRECTING AUTOMATICALLY IN ${timeleft} SECONDS...` : "REDIRECTING HOME...";
    timeleft -= 1;
}, 1000);
</script>
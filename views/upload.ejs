<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload</title>
</head>
<%- include('partials/header') %>
<body>

    <form action="">
        <div>
            <label for="meme_title">Meme Title</label>
            <br>
            <input type="text" name="meme_title" id="meme_title">
        </div>
        <br>
        <div>
            <label for="image">Upload Your Meme (jpg,png)</label>
            <br>
            <input type="file" name="image" id="image">
        </div>
        <br>
        <div>
            <textarea name="description" id="description"></textarea>
        </div>

        <input type="submit" value="post meme">
    </form>
</body>
</html>
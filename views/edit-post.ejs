<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/x-icon" href="/img/icon.png">
    <link rel="stylesheet" href="/css/style.css">
    <title>Edit Post</title>
</head>

<%- include('partials/header', { sessionUser, showActions: true }) %>

<body>
<% if (success) { %>
    <div id="successMsg" style="color:green;">
        <h3>Post Updated ╰(*°▽°*)╯</h3>
    </div>
<% } %>

<% if (error) { %>
    <p style="color:red"><%= error %></p>
<% } %>

<form action="/upload/update" method="POST">
    <input type="hidden" name="postId" value="<%= postData._id %>">
    <input type="hidden" name="authorId" value="<%= postData.author._id %>">
    <input type="hidden" name="backURL" value="<%= backURL %>">

    <div>
        <label for="meme_title">Meme Title</label>
        <br>
        <input 
            type="text" 
            name="meme_title" 
            id="meme_title" 
            value="<%= postData.title %>" 
            required
        >
    </div>

    <br>

    <div>
        <label for="imageFile">Upload New Meme (optional)</label>
        <br>
        <input type="file" id="imageFile" accept="image/png, image/jpeg, image/gif">
    </div>

    <br>

    <div>
        <p>Current / New Preview</p>
        <img 
            id="preview" 
            src="<%= postData.image %>" 
            style="display:block; max-width:300px;"
        >
    </div>

    <br>

    <div>
        <label for="description">Description</label>
        <br>
        <textarea name="description" id="description" required><%= postData.description %></textarea>
    </div>

    <input 
        type="hidden" 
        name="image_base64" 
        id="image_base64" 
        value="<%= postData.image %>"
    >

    <br>
    <input type="submit" value="update post">
</form>

<script>
const imageInput = document.getElementById("imageFile");
const preview = document.getElementById("preview");
const hiddenBase64 = document.getElementById("image_base64");

imageInput.addEventListener("change", function () {
    const file = this.files[0];

    if (!file) {
        return;
    }

    const reader = new FileReader();

    reader.onload = function (e) {
        const base64String = e.target.result;
        preview.src = base64String;
        preview.style.display = "block";
        hiddenBase64.value = base64String;
    };

    reader.readAsDataURL(file);
});

const successMsg = document.getElementById("successMsg");

if (successMsg) {
    setTimeout(() => {
        successMsg.style.transition = "opacity 0.5s";
        successMsg.style.opacity = "0";

        setTimeout(() => {
            successMsg.style.display = "none";
        }, 500);
    }, 3000);
}
</script>

</body>
</html>
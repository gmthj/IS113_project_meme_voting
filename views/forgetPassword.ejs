<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/x-icon" href="/img/icon.png">
    <link rel="stylesheet" href="/css/style.css">
    <title>Forget Password</title>
</head>
<%- include('partials/header', {sessionUser:{}, showActions: true}) %>
<body>

    <h2>Forgot Password</h2>

<% if (error) { %>
    <p style="color:red;"><%= error %></p>
<% } %>

<% if (success) { %>
    <p id="successMessage" style="color:green;"></p>

    <script>
        let seconds = 3;
        const messageEl = document.getElementById("successMessage");

        function updateMessage() {
            messageEl.textContent = `Password updated successfully. Redirecting to login in ${seconds}s`;
        }

        updateMessage();

        const interval = setInterval(() => {
            seconds--;

            if (seconds > 0) {
                updateMessage();
            } else {
                clearInterval(interval);
                window.location.href = "/account/login";
            }
        }, 1000);
    </script>
<% } %>

<form action="/account/forget-password" method="POST">
    <div>
        <label for="email">Email</label><br>
        <input type="email" id="email" name="email" required>
    </div>

    <div>
        <label for="dob">Date of Birth</label><br>
        <input type="date" id="dob" name="dob" required>
    </div>

    <div>
        <label for="newPassword">New Password</label><br>
        <input type="password" id="newPassword" name="newPassword" required>
    </div>

    <div>
        <label for="confirmPassword">Confirm New Password</label><br>
        <input type="password" id="confirmPassword" name="confirmPassword" required>
    </div>

    <br>
    <button type="submit">Reset Password</button>
</form>

<nav style="display: flex; justify-content: center; gap: 20px; margin-top: 20px;">
    <a href="/account/login">Back to Login</a>
    <a href="/account/register">Register</a>
</nav>
</body>
</html>


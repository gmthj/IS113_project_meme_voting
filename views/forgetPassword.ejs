<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/x-icon" href="/img/icon.png">
    <link rel="stylesheet" href="/css/style.css">
    <title>Forget Password</title>
</head>

<body>
    <%- include('partials/header', {sessionUser: sessionUser || {}, showActions: true}) %>

    <main class="home-container form-center-wrapper">
        <div class="neo-card">
            <div class="neo-card-header">
                <h2>FORGOT PASSWORD</h2>
            </div>
            <div class="neo-card-body">
                <% if (error) { %>
                    <div class="error-message">
                    <% if (Array.isArray(error)) { %>
                        <ul>
                        <% error.forEach(function(err) { %>
                            <li><%= err %></li>
                        <% }); %>
                        </ul>
                    <% } else { %>
                        <p><%= error %></p>
                    <% } %>
                    </div>
                <% } %>
            
                <% if (success) { %>
                    <div id="successMessage" class="neo-success-sticker flash-msg"></div>
            
                    <script>
                        let seconds = 3;
                        const messageEl = document.getElementById("successMessage");
            
                        function updateMessage() {
                            messageEl.textContent = `Password updated successfully. Redirecting to login in ${seconds}s`;
                        }
            
                        updateMessage();
            
                        const interval = setInterval(() => {
                            seconds--;
            
                            if (seconds > 0) {
                                updateMessage();
                            } else {
                                clearInterval(interval);
                                window.location.href = "/account/login";
                            }
                        }, 1000);
                    </script>
                <% } %>
            
                <form action="/account/forget-password" method="POST">
                    <div class="neo-form-group">
                        <label for="email" class="neo-label">Email:</label>
                        <input type="email" id="email" name="email" value="<%= formData?.email || '' %>" required class="neo-input">
                    </div>
            
                    <div class="neo-form-group">
                        <label for="dob" class="neo-label">Date of Birth:</label>
                        <input type="date" id="dob" name="dob" value="<%= formData?.dob || '' %>" required class="neo-input">
                    </div>
            
                    <div class="neo-form-group">
                        <label for="newPassword" class="neo-label">New Password:</label>
                        <input type="password" id="newPassword" name="newPassword" required class="neo-input">
                    </div>
            
                    <div class="neo-form-group last">
                        <label for="confirmPassword" class="neo-label">Confirm New Password:</label>
                        <input type="password" id="confirmPassword" name="confirmPassword" required class="neo-input">
                    </div>
            
                    <button type="submit" class="neo-btn neo-btn-yellow full-width">RESET PASSWORD</button>
                </form>
            </div>
            <div class="neo-card-footer neo-footer-row">
                <a href="/account/login" class="neo-btn neo-btn-white">BACK TO LOGIN</a>
                <a href="/account/register" class="neo-btn neo-btn-violet">REGISTER</a>
            </div>
        </div>
    </main>
</body>

<script>
    const dateInput = document.getElementById("dob");

    if (dateInput) {
        dateInput.addEventListener("click", function () {
            if (this.showPicker) {
                this.showPicker();
            }
        });
    }
</script>

</html>

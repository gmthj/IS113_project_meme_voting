<div class="sort-wrapper">
    <div class="sort-left">
        <div class="sort-tabs">
            <% 
                const commonQuery = (onlyBookmarks ? '&bookmark=true' : '') + ((typeof isAnnon !== 'undefined' && isAnnon) ? '&annon=true' : '');
                const isVotes = currentSort === 'highest-votes' || currentSort === 'lowest-votes' || (!currentSort);
                const isTime = currentSort === 'newest' || currentSort === 'oldest';
                const isComments = currentSort === 'most-comments' || currentSort === 'least-comments';
            %>
            
            <a href="<%= baseUrl %>?sort=<%= currentSort === 'highest-votes' ? 'lowest-votes' : 'highest-votes' %><%= commonQuery %>"
               class="sort-tab <%= isVotes ? 'active' : '' %>">
               <%= currentSort === 'lowest-votes' ? 'LOWEST' : 'TOP' %>
            </a>

            <a href="<%= baseUrl %>?sort=<%= currentSort === 'newest' ? 'oldest' : 'newest' %><%= commonQuery %>"
               class="sort-tab <%= isTime ? 'active' : '' %>">
               <%= currentSort === 'oldest' ? 'OLDEST' : 'NEWEST' %>
            </a>

            <% if (!isFullPost) { %>
               <a href="<%= baseUrl %>?sort=<%= currentSort === 'most-comments' ? 'least-comments' : 'most-comments' %><%= commonQuery %>"
                  class="sort-tab <%= isComments ? 'active' : '' %>">
                  <%= currentSort === 'least-comments' ? 'LEAST COMMENTS' : 'MOST COMMENTS' %>
               </a>

               <form action="<%= resetUrl %>?redirect=<%= baseUrl %>" method="POST" style="margin:0; padding:0;">
                  <button type="submit" class="reset-btn">RESET</button>
               </form>
               <a href="<%= baseUrl %>?bookmark=<%= !onlyBookmarks ? 'true' : 'false' %>&sort=<%= currentSort || 'highest-votes' %><%= (typeof isAnnon !== 'undefined' && isAnnon) ? '&annon=true' : '' %>"
                  class="sort-tab bookmark-tab <%= onlyBookmarks ? 'active' : '' %>">BOOKMARKS</a>
            <% } %>
        </div>
    </div>
    
</div>


<div class="neo-card" id="post-<%= post._id %>"> <!--  style="width: 30em; margin: 0 auto;" -->


    <div class="neo-card-header">
        <a href="/user/<%= post.author._id %>" class="neo-author-link">
            <img src="<%= post.author.avatar %>" class="neo-avatar-sm">
            <%= post.author.name %>
        </a>

        <% if (post.edit_datetime) { %>
            <span class="neo-edited-label">EDITED</span>
        <% } %>

        <span class="neo-badge">
            <%= post.postAge %>
        </span>
    </div>

    <div class="neo-card-body">
        <a href="/fullpost/<%= post._id %>">
            <h2 class="neo-post-title"><%= post.title %></h2>
            
            <div class="neo-img-box">
                <img src="<%= post.image %>" alt="meme image" referrerpolicy="no-referrer">
            </div>
            
            <p style="font-weight: 700;"><%= post.description %></p>
        </a>
    </div>



    <% if (showControls) { %>

        <div class="neo-card-footer">
            
            <div class="vote-block">
                <form action="/vote" method="post" style="display: contents;">
                    <input type="hidden" name="userId" value="<%= sessionUser._id %>">
                    <input type="hidden" name="postId" value="<%= post._id %>">
                    <input type="hidden" name="voteValue" value="<%= post.voteValue %>">
                    
                    <button type="submit" name="vote" value="up" 
                            class="vote-btn <%= post.voteValue === true ? 'up-active' : '' %>">
                        <%= post.voteValue === true ? "🔼" : "🔺" %>
                    </button>

                    <div class="vote-score"><%= post.vote_score %></div>

                    <button type="submit" name="vote" value="down" 
                            class="vote-btn <%= post.voteValue === false ? 'down-active' : '' %>">
                        <%= post.voteValue === false ? "🔽" : "🔻" %>
                    </button>
                </form>
            </div>

            <a href="/fullpost/<%= post._id %>" style="text-decoration: none; font-weight: 900; color: black;">
                💬 <%= post.comment_count %>
            </a>

            <div style="margin-left: auto; display: flex; gap: 10px;">
                <% if (post.author._id == sessionUser._id) { %>
                    <form action="/upload/edit" method="post">
                        <input type="hidden" name="authorId" value="<%= post.author._id %>">
                        <input type="hidden" name="postId" value="<%= post._id %>">
                        <button type="submit" class="neo-btn neo-btn-yellow" style="padding: 5px 10px; font-size: 0.8rem;">EDIT</button>
                    </form>
                    
                    <form action="/delete" method="post">
                        <input type="hidden" name="authorId" value="<%= post.author._id %>">
                        <input type="hidden" name="postId" value="<%= post._id %>">
                        <input type="hidden" name="post" value="<%= JSON.stringify(post) %>">
                        <button type="submit" class="neo-btn neo-btn-red" style="padding: 5px 10px; font-size: 0.8rem;">DELETE</button>
                    </form>
                <% } %>
                    
                <form action="/bookmark" method="post" class="bookmark-form">
                    <input type="hidden" name="postId" value="<%= post._id %>">
                    <button type="submit" class="bookmark-btn <%= post.bookmark ? 'bookmark-active' : '' %>">
                        <% if (post.bookmark) { %>
                            <img src="/img/bookmark-on.png" class="bookmark-icon">
                            <% } else { %>
                            <img src="/img/bookmark-off.png" class="bookmark-icon">
                        <% } %>
                    </button>
                </form>
            </div>
            
        </div> 

    <% } %>
</div>
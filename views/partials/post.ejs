
<table border="1" id="post-<%= post._id %>" style="width: 20em;"> <!--  style="width: 30em; margin: 0 auto;" -->
    <tr><td>

        <h2>
            <a href="/fullpost/<%= post._id %>" style="text-decoration:none; color: inherit;">
                <%= post.title %>
            </a>
        </h2>

        <h3>
            <a href="/user/<%= post.author._id %>" style="text-decoration:none; color: inherit;">
                <img src="<%= post.author.avatar %>" style="height: 1em">
                <%= post.author.name %>
            </a>

            <a href="/fullpost/<%= post._id %>" style="text-decoration:none; color: inherit;">
                • <%= post.postAge %>
            </a>
        </h3>
        
        <a href="/fullpost/<%= post._id %>" style="text-decoration:none; color: inherit;">

            <img src=" <%= post.image %>" alt="meme image" referrerpolicy="no-referrer" style="width: 100%">
        
            <p><%= post.description %></p>
            
            <% if (showControls) { %>
                <table>
                    <tr>
                        <td><!-- vote controls -->
                            <form action="/vote" method="post">
                                <input type="hidden" name="userId" value="<%= sessionUser._id %>">
                                <input type="hidden" name="postId" value="<%= post._id %>">
                                <input type="hidden" name="voteValue" value="<%= post.voteValue %>">
                                
                                <button type="submit" name="vote" value="up">
                                    <%= post.voteValue === true  ? "🔼" : "🔺" %>
                                </button>

                                <%= post.vote_score %>

                                <button type="submit" name="vote" value="down">
                                    <%= post.voteValue === false ? "🔽" : "🔻" %>
                                </button>
                            </form>
                        </td>

    
                        <td>
                            &nbsp; | &nbsp;
                            💬: <%= post.comment_count %>
                        </td>
    
        
                        <% if (post.author._id == sessionUser._id) { %>
                            <td>
                                <form action="/upload/edit" method="post">
                                    &nbsp; | &nbsp;
                                    <input type="hidden" name="authorId" value="<%= post.author._id %>">
                                    <input type="hidden" name="postId" value="<%= post._id %>">
                                    <button type="submit">Edit</button>
                                </form>
                            </td>
    
                            <td>
                                <form action="/delete" method="post">
                                    &nbsp; | &nbsp;
                                    <input type="hidden" name="authorId" value="<%= post.author._id %>">
                                    <input type="hidden" name="postId" value="<%= post._id %>">
                                    <input type="hidden" name="post" value="<%= JSON.stringify(post) %>">
                                    <button type="submit">Delete</button>
                                </form>
                            </td>
                        <% } %>
    
                    </tr>
                </table>
            <% } %>
        </a>

    </td></tr>
</table>



<table border="1" id="post-<%= post._id %>">
    <tr><td>

        <h2><%= post.title %></h2>
        <h3><img src="<%= post.userId.avatar %>" style="height: 1em">
            <%= post.userId.name %> • <%= post.postAge %></h3>
        
        <img src=" <%= post.image %>" alt="could not load image" referrerpolicy="no-referrer" style="height: 20em">
    
        <p><%= post.description %></p>
        
        <table>
            <tr>
                <td>
                    Vote
                </td>
                <td>
                    <form action="/vote" method="post">
                        <input type="hidden" name="vote" value=<%= post.voteValue === true  ? "" : "up" %>>
                        <input type="hidden" name="userId" value=<%= currentUser ? currentUser._id : '' %>>  <!-- TODO: change to current user -->
                        <input type="hidden" name="postId" value=<%= post._id %>>
                        <input type="hidden" name="voteValue" value=<%= post.voteValue %>>
                        <button type="submit">
                            <%= post.voteValue === true  ? "🔼" : "🔺" %>
                        </button>
                    </form>
                </td>
                <td>
                    <%= post.vote_score %>
                </td>
                <td>
                    <form action="/vote" method="post">
                        <input type="hidden" name="vote" value=<%= post.voteValue === false ? "" : "down" %>>
                        <input type="hidden" name="userId" value=<%= currentUser ? currentUser._id : '' %>>  <!-- TODO: change to current user -->
                        <input type="hidden" name="postId" value=<%= post._id %>>
                        <input type="hidden" name="voteValue" value=<%= post.voteValue %>>
                        <button type="submit">
                            <%= post.voteValue === false ? "🔽" : "🔻" %>
                        </button>
                    </form>
                </td>
            </tr>
        </table>


    </td></tr>
</table>